#!/usr/bin/env bash
# Download the PHP bottle + transitive runtime deps for the requested
# version into $ASDF_DOWNLOAD_PATH.
#
# Layout written:
#   $ASDF_DOWNLOAD_PATH/
#     manifest.txt        — "<name> <tag> <digest> <file>" per line
#     <name>-<tag>.tar.gz — bottle tarballs (php first, then deps)

set -euo pipefail

plugin_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/utils.bash
source "$plugin_dir/lib/utils.bash"
# shellcheck source=../lib/formula.bash
source "$plugin_dir/lib/formula.bash"
# shellcheck source=../lib/ghcr.bash
source "$plugin_dir/lib/ghcr.bash"
# shellcheck source=../lib/deps.bash
source "$plugin_dir/lib/deps.bash"
# shellcheck source=../lib/history.bash
source "$plugin_dir/lib/history.bash"

: "${ASDF_INSTALL_VERSION:?ASDF_INSTALL_VERSION is required}"
: "${ASDF_DOWNLOAD_PATH:?ASDF_DOWNLOAD_PATH is required}"

version="$ASDF_INSTALL_VERSION"
if [[ ! "$version" =~ ^([0-9]+\.[0-9]+)\.[0-9]+ ]]; then
  asdf_php_die "version must be MAJOR.MINOR.PATCH (got: $version)"
fi
majmin="${BASH_REMATCH[1]}"

mkdir -p "$ASDF_DOWNLOAD_PATH"
manifest="$ASDF_DOWNLOAD_PATH/manifest.txt"
: > "$manifest"

# Filesystem-safe filename for a formula name (@ stays; macOS allows it).
file_for() {
  local name="$1" tag="$2"
  echo "${ASDF_DOWNLOAD_PATH}/${name}-${tag}.tar.gz"
}

# 1. Resolve which tap/core refs to use.
# Fast path: requested version matches what the current tap pins.
# Historical path: walk tap history for the commit that pinned it, then
# pick the contemporary homebrew-core commit so deps come from the era
# the bottle was built against (otherwise modern openssl/libpq ABI
# divergence breaks libpq.5.dylib symbol lookup).
current_content="$(asdf_php_formula_fetch "$majmin")"
current_version="$(printf '%s' "$current_content" | asdf_php_formula_version)" \
  || asdf_php_die "could not parse version from current php@${majmin} formula"

if [[ "$current_version" == "$version" ]]; then
  formula_content="$current_content"
  core_ref="master"
  asdf_php_log "using current tap formula (php@${majmin}=${version})"
else
  asdf_php_log "version ${version} differs from current tap (${current_version}); resolving historical refs..."
  read -r tap_ref tap_date < <(asdf_php_history_find_tap_ref "$majmin" "$version")
  core_ref="$(asdf_php_history_find_core_ref "$tap_date")"
  formula_content="$(asdf_php_formula_fetch "$majmin" "$tap_ref")"
  asdf_php_log "tap_ref=${tap_ref:0:8} (${tap_date}); core_ref=${core_ref:0:8}"
fi

root_url="$(printf '%s' "$formula_content" | asdf_php_formula_bottle_root_url)" \
  || asdf_php_die "no bottle root_url in php@${majmin}"

read -r bottle_tag bottle_digest < <(printf '%s' "$formula_content" | asdf_php_formula_bottle_resolve) \
  || asdf_php_die "no compatible bottle for $(asdf_php_host_tag) in php@${majmin}"

php_repo="$(asdf_php_ghcr_repo_path "$root_url" "php@${majmin}")"
php_file="$(file_for "php@${majmin}" "$bottle_tag")"

asdf_php_log "downloading php@${majmin}=${version} ($bottle_tag) from $php_repo"
asdf_php_ghcr_fetch_blob "$php_repo" "$bottle_digest" "$php_file"
printf 'php@%s %s %s %s\n' "$majmin" "$bottle_tag" "$bottle_digest" "$(basename "$php_file")" >> "$manifest"

# 2. Transitive deps (at the contemporary homebrew-core ref)
asdf_php_log "resolving transitive dep DAG at core ref ${core_ref:0:8}..."
deps_lines="$(printf '%s' "$formula_content" | asdf_php_deps_walk "$core_ref")"
dep_count=$(printf '%s' "$deps_lines" | grep -cv '^$' || true)
asdf_php_log "resolved $dep_count deps; downloading..."

# Read dep lines and pull each
while IFS=' ' read -r name root_url tag digest; do
  [[ -z "$name" ]] && continue
  repo="$(asdf_php_ghcr_repo_path "$root_url" "$name")"
  dest="$(file_for "$name" "$tag")"
  asdf_php_log "  $name ($tag)"
  asdf_php_ghcr_fetch_blob "$repo" "$digest" "$dest"
  printf '%s %s %s %s\n' "$name" "$tag" "$digest" "$(basename "$dest")" >> "$manifest"
done <<< "$deps_lines"

total_size="$(du -sh "$ASDF_DOWNLOAD_PATH" | awk '{print $1}')"
asdf_php_log "done — wrote $(wc -l < "$manifest" | tr -d ' ') tarballs ($total_size) to $ASDF_DOWNLOAD_PATH"
